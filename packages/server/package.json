{
  "name": "@silverbackbase/trail",
  "version": "0.1.0",
  "description": "Multi-touch attribution tracker — self-hosted, runs anywhere Node.js runs",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "trail": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SilverBackBase/Trail.git"
  },
  "homepage": "https://github.com/SilverBackBase/Trail",
  "keywords": ["attribution", "analytics", "multi-touch", "tracker", "mcp"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/embed-tracker.cjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
